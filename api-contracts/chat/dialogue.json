{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dialogue API (对话接口)",
  "description": "多轮对话引导契约。后端传入用户消息与当前会话状态，Agent 执行槽位抽取、校验并返回追问。\n对应 Agent: agent/dialogue_agent.py DialogueAgent.run(session, message)\n对应 Prompt: agent/prompts/dialogue_system.txt",

  "request": {
    "description": "后端 → Agent 的对话请求",
    "type": "object",
    "required": ["session_id", "message", "contract_type", "slots"],
    "properties": {
      "session_id": {
        "type": "integer",
        "description": "合同起草会话 ID，对应数据库 ContractSession.id"
      },
      "contract_type": {
        "type": "string",
        "enum": ["tech_service", "procurement", "employment", "cooperation", "non_disclosure"],
        "description": "合同类型编码"
      },
      "message": {
        "type": "string",
        "maxLength": 2000,
        "description": "用户最新输入的文本"
      },
      "slots": {
        "type": "object",
        "description": "当前已收集的合同要素键值对，key 为字段名，value 为已提取的值或空字符串",
        "patternProperties": {
          "^[a-z_]+$": { "type": "string" }
        },
        "additionalProperties": false
      },
      "history": {
        "type": "array",
        "description": "对话历史（可选，用于上下文理解）",
        "items": {
          "type": "object",
          "required": ["role", "content"],
          "properties": {
            "role": { "type": "string", "enum": ["user", "ai"] },
            "content": { "type": "string" }
          }
        }
      }
    }
  },

  "response": {
    "description": "Agent → 后端的对话响应",
    "type": "object",
    "required": ["intent", "slots"],
    "properties": {
      "intent": {
        "type": "string",
        "enum": ["continue", "complete"],
        "description": "continue=槽位未收齐需继续追问；complete=所有必填槽位已收齐"
      },
      "slots": {
        "type": "object",
        "description": "更新后的合同要素（合并了本次提取的字段）",
        "patternProperties": {
          "^[a-z_]+$": { "type": "string" }
        }
      },
      "next_field": {
        "type": ["string", "null"],
        "description": "下一个待填写的字段名，intent=complete 时为 null"
      },
      "reply": {
        "type": ["string", "null"],
        "description": "Agent 生成的追问问题（自然语言），intent=complete 时为 null",
        "examples": ["甲方的全称是什么？", "合同总金额是多少？"]
      },
      "missing": {
        "type": "array",
        "description": "剩余未填写的必填字段列表",
        "items": { "type": "string" }
      }
    }
  },

  "examples": {
    "request": {
      "session_id": 1,
      "contract_type": "tech_service",
      "message": "甲方是深圳科技有限公司",
      "slots": {},
      "history": []
    },
    "response": {
      "intent": "continue",
      "slots": { "party_a": "深圳科技有限公司" },
      "next_field": "party_b",
      "reply": "乙方（受托方）的全称是什么？",
      "missing": ["party_b", "subject", "amount", "term", "payment", "penalty", "jurisdiction"]
    }
  }
}
