{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RAG Search API (知识库检索接口)",
  "description": "知识库语义检索契约。后端传入查询文本与过滤条件，Agent 服务层执行向量检索（FAISS + sentence-transformers）并返回相关片段。\n对应服务: backend/app/services/rag_service.py (需接入 agent 层 FAISS 检索逻辑)",

  "request": {
    "description": "后端 → Agent 知识库的检索请求",
    "type": "object",
    "required": ["query"],
    "properties": {
      "query": {
        "type": "string",
        "minLength": 2,
        "maxLength": 500,
        "description": "检索查询文本（自然语言问题或关键词）"
      },
      "contract_type": {
        "type": "string",
        "enum": ["tech_service", "procurement", "employment", "cooperation", "non_disclosure", ""],
        "description": "按合同类型筛选（可选），传空字符串表示不筛选"
      },
      "top_k": {
        "type": "integer",
        "minimum": 1,
        "maximum": 20,
        "default": 5,
        "description": "返回的最相似片段数量"
      }
    }
  },

  "response": {
    "description": "Agent 知识库 → 后端的检索响应",
    "type": "object",
    "required": ["query", "total", "chunks"],
    "properties": {
      "query": {
        "type": "string",
        "description": "回显原始查询"
      },
      "total": {
        "type": "integer",
        "description": "命中的总片段数（不超过 top_k）"
      },
      "chunks": {
        "type": "array",
        "description": "检索结果片段列表，按相关性得分降序排列",
        "items": {
          "type": "object",
          "required": ["source", "content", "score"],
          "properties": {
            "source": {
              "type": "string",
              "description": "片段来源，格式: {知识库类型}/{文件名}，如 templates/tech_service.json、legal_docs/民法典合同编摘要.json"
            },
            "content": {
              "type": "string",
              "description": "片段文本内容"
            },
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "余弦相似度得分，越接近 1 越相关"
            },
            "metadata": {
              "type": "object",
              "description": "附加元数据（可选）",
              "properties": {
                "clause_no": { "type": "integer", "description": "条款编号" },
                "clause_title": { "type": "string", "description": "条款标题" }
              }
            }
          }
        }
      }
    }
  },

  "examples": {
    "request": {
      "query": "技术服务合同的管辖权条款如何约定",
      "contract_type": "tech_service",
      "top_k": 3
    },
    "response": {
      "query": "技术服务合同的管辖权条款如何约定",
      "total": 3,
      "chunks": [
        {
          "source": "templates/tech_service.json",
          "content": "第十三条 争议解决\n因本合同引起的或与本合同有关的任何争议，双方应友好协商解决；协商不成的，任何一方均可向甲方所在地人民法院提起诉讼。",
          "score": 0.92,
          "metadata": { "clause_no": 13, "clause_title": "争议解决" }
        },
        {
          "source": "legal_docs/民法典合同编摘要.json",
          "content": "《民法典》第XXX条：当事人可以协议选择管辖法院，但不得违反本法对级别管辖和专属管辖的规定。",
          "score": 0.85
        }
      ]
    }
  }
}